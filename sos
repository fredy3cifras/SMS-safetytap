<!DOCTYPE html>
<html>
<head>
  <title>SafetyTap SOS</title>
</head>

<body>
<h2>Sending SOS...</h2>

<script>
navigator.geolocation.getCurrentPosition(function(position) {

  // 1. Obtener coordenadas GPS
  const lat = position.coords.latitude;
  const lon = position.coords.longitude;

  // 2. Crear link de Google Maps
  const location = "https://maps.google.com/?q=" + lat + "," + lon;

  // 3. MENSAJE SMS
  const message = "SafetyTap Alert: I need help. My location: " + location;

  // 4. LINK SMS (iPhone Messages app)
  const sms = "sms:+1234567890&body=" + encodeURIComponent(message);

  // 5. Redirigir a Mensajes
  window.location.href = sms;

});
</script>

</body>
</html>
